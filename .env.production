# Production Environment Variables
# Copy this file and fill in your actual values

# MongoDB Atlas (get from mongodb.com)
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/hmif-platform

# Admin Password
ADMIN_PASSWORD=your-secure-password-here

# API URLs (update after deploying)
VITE_API_URL=https://your-backend-url.onrender.com
VITE_CHATBOT_URL=https://your-chatbot-url.onrender.com

# For Python Chatbot Service
GROQ_API_KEY=your-groq-api-key-here
